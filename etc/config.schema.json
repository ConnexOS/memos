{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MemoConfig",
  "type": "object",
  "properties": {
    "chroma": {
      "type": "object",
      "properties": {
        "path": {
          "title": "Path",
          "type": "string"
        },
        "collection_name": {
          "default": "project_memory",
          "title": "Collection Name",
          "type": "string"
        },
        "timeout": {
          "default": 30,
          "title": "Timeout",
          "type": "integer"
        }
      },
      "required": [],
      "additionalProperties": false
    },
    "model": {
      "type": "object",
      "properties": {
        "path": {
          "title": "Path",
          "type": "string"
        },
        "name": {
          "default": "bge-large-zh-v1.5",
          "title": "Name",
          "type": "string"
        },
        "vector_dim": {
          "default": 1024,
          "title": "Vector Dim",
          "type": "integer"
        },
        "download_retries": {
          "default": 3,
          "title": "Download Retries",
          "type": "integer"
        },
        "download_timeout": {
          "default": 600,
          "title": "Download Timeout",
          "type": "integer"
        },
        "verify_sha256": {
          "default": false,
          "title": "Verify Sha256",
          "type": "boolean"
        }
      },
      "required": [],
      "additionalProperties": false
    },
    "llm": {
      "type": "object",
      "properties": {
        "endpoints": {
          "items": {
            "description": "单个 LLM 端点配置",
            "properties": {
              "name": {
                "default": "default",
                "title": "Name",
                "type": "string"
              },
              "api_base": {
                "default": "http://localhost:11434/v1",
                "title": "Api Base",
                "type": "string"
              },
              "api_key": {
                "default": "",
                "title": "Api Key",
                "type": "string"
              },
              "model": {
                "default": "",
                "title": "Model",
                "type": "string"
              },
              "prompt_templates": {
                "additionalProperties": {
                  "type": "string"
                },
                "title": "Prompt Templates",
                "type": "object"
              }
            },
            "title": "LLMEndpoint",
            "type": "object"
          },
          "title": "Endpoints",
          "type": "array"
        },
        "active": {
          "default": "default",
          "title": "Active",
          "type": "string"
        },
        "temperature": {
          "default": 0.1,
          "title": "Temperature",
          "type": "number"
        },
        "max_tokens": {
          "default": 2048,
          "title": "Max Tokens",
          "type": "integer"
        },
        "request_timeout": {
          "default": 600,
          "title": "Request Timeout",
          "type": "integer"
        },
        "max_retries": {
          "default": 3,
          "title": "Max Retries",
          "type": "integer"
        },
        "retry_base_delay": {
          "default": 1.0,
          "title": "Retry Base Delay",
          "type": "number"
        },
        "stop": {
          "default": [
            "<|im_end|>"
          ],
          "items": {
            "type": "string"
          },
          "title": "Stop",
          "type": "array"
        }
      },
      "required": [],
      "additionalProperties": false
    },
    "memory": {
      "type": "object",
      "properties": {
        "decay_lambda": {
          "default": 0.02,
          "description": "时间衰减系数，越大越偏向近期记忆。0=不衰减",
          "minimum": 0.0,
          "title": "Decay Lambda",
          "type": "number"
        },
        "similarity_threshold": {
          "default": 0.55,
          "description": "去重相似度阈值（余弦距离），低于此值判定重复",
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Similarity Threshold",
          "type": "number"
        },
        "dedup_top_k": {
          "default": 1,
          "description": "去重检查的候选记忆数，0=不检查",
          "minimum": 0,
          "title": "Dedup Top K",
          "type": "integer"
        },
        "default_top_k": {
          "default": 5,
          "description": "检索默认返回条数",
          "maximum": 50,
          "minimum": 1,
          "title": "Default Top K",
          "type": "integer"
        },
        "default_type": {
          "default": "fact",
          "description": "新建记忆的默认类型（fact/decision/preference/todo）",
          "title": "Default Type",
          "type": "string"
        },
        "archive_days": {
          "default": 90,
          "description": "超过此天数的记忆自动归档（软删除），0=不归档",
          "minimum": 0,
          "title": "Archive Days",
          "type": "integer"
        },
        "rerank_multiplier": {
          "default": 3,
          "description": "重排序候选倍数，增大提高质量但降低速度",
          "minimum": 1,
          "title": "Rerank Multiplier",
          "type": "integer"
        },
        "rerank_min_candidates": {
          "default": 30,
          "description": "重排序最小候选数，低于此值直接返回",
          "minimum": 1,
          "title": "Rerank Min Candidates",
          "type": "integer"
        },
        "quality_threshold": {
          "default": 0.5,
          "description": "质量评分参考阈值，低于此值标记为低质量",
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Quality Threshold",
          "type": "number"
        },
        "conflict_detection_enabled": {
          "default": true,
          "description": "新记忆与已有记忆的冲突检测开关",
          "title": "Conflict Detection Enabled",
          "type": "boolean"
        },
        "conflict_distance_threshold": {
          "default": 0.85,
          "description": "冲突检测预过滤阈值，相似度≥此值才检测（v0.4.5 从 0.55 调升至 0.85）",
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Conflict Distance Threshold",
          "type": "number"
        },
        "conflict_use_llm": {
          "default": true,
          "description": "冲突检测是否调用 LLM 判断矛盾；false 时纯向量判断（sim>threshold→冲突，降级模式）",
          "title": "Conflict Use Llm",
          "type": "boolean"
        },
        "daily_todo_time": {
          "default": "18:00",
          "description": "每日待办提醒时间（HH:MM，服务器本地时间）",
          "title": "Daily Todo Time",
          "type": "string"
        },
        "expiry_warn_days": {
          "default": 30,
          "description": "过期警告提前天数",
          "minimum": 0,
          "title": "Expiry Warn Days",
          "type": "integer"
        },
        "reuse_weight": {
          "default": 0.1,
          "description": "复用频率加成权重（0=禁用）",
          "minimum": 0.0,
          "title": "Reuse Weight",
          "type": "number"
        },
        "reuse_decay": {
          "default": 0.01,
          "description": "复用频率时间衰减系数",
          "minimum": 0.0,
          "title": "Reuse Decay",
          "type": "number"
        },
        "reuse_boost_cap": {
          "default": 0.5,
          "description": "复用频率加成上限",
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Reuse Boost Cap",
          "type": "number"
        },
        "default_status": {
          "default": "active",
          "description": "新建记忆默认状态（active/archived）",
          "title": "Default Status",
          "type": "string"
        },
        "daily_review_chunk_tokens": {
          "default": 12000,
          "description": "每日回顾分片最大 token 数（BATCH/PRE_SUMMARIZE 策略）",
          "maximum": 64000,
          "minimum": 2000,
          "title": "Daily Review Chunk Tokens",
          "type": "integer"
        },
        "daily_review_chunk_rounds": {
          "default": 30,
          "description": "每日回顾分片最大轮次数（作为 token 分片的补充上限）",
          "maximum": 100,
          "minimum": 5,
          "title": "Daily Review Chunk Rounds",
          "type": "integer"
        }
      },
      "required": [],
      "additionalProperties": false
    },
    "suggestion": {
      "type": "object",
      "properties": {
        "enable_active_suggestions": {
          "default": true,
          "description": "主动推送全局开关",
          "title": "Enable Active Suggestions",
          "type": "boolean"
        },
        "active_suggestion_threshold": {
          "default": 0.65,
          "description": "Layer 2 推送相似度阈值，相似度≥此值的记忆触发主动建议",
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Active Suggestion Threshold",
          "type": "number"
        },
        "context_injection_threshold": {
          "default": 0.5,
          "description": "Layer 1 上下文注入阈值，相似度≥此值的记忆注入 AI 助手上下文",
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Context Injection Threshold",
          "type": "number"
        },
        "context_max_items": {
          "default": 3,
          "description": "Layer 1 最大注入条数，超出截断",
          "maximum": 10,
          "minimum": 1,
          "title": "Context Max Items",
          "type": "integer"
        },
        "suggestion_cooldown_minutes": {
          "default": 30,
          "description": "同一记忆的冷却期（分钟），冷却期内不再重复推送",
          "minimum": 0,
          "title": "Suggestion Cooldown Minutes",
          "type": "integer"
        },
        "suggestion_max_per_day": {
          "default": 10,
          "description": "管道一每日最大推送数（24h 滑动窗口）",
          "minimum": 0,
          "title": "Suggestion Max Per Day",
          "type": "integer"
        },
        "suggestion_expiry_days": {
          "default": 7,
          "description": "建议自动过期天数（0=不过期）",
          "minimum": 0,
          "title": "Suggestion Expiry Days",
          "type": "integer"
        },
        "suggestion_max_pending": {
          "default": 50,
          "description": "最大待处理建议数，超出时 FIFO 自动清理",
          "maximum": 200,
          "minimum": 10,
          "title": "Suggestion Max Pending",
          "type": "integer"
        },
        "suggestion_display_limit": {
          "default": 20,
          "description": "Dashboard 单次拉取建议数（分页大小）",
          "maximum": 100,
          "minimum": 5,
          "title": "Suggestion Display Limit",
          "type": "integer"
        },
        "suggestion_manual_daily_limit": {
          "default": 5,
          "description": "[已废弃] 管道三（手工建议）每日推送上限，由 max_injection_per_round 替代",
          "maximum": 20,
          "minimum": 0,
          "title": "Suggestion Manual Daily Limit",
          "type": "integer"
        },
        "max_injection_per_round": {
          "default": 5,
          "description": "每轮会话最多注入的记录数（人工建议 + 知识匹配），按优先级排序后截断",
          "maximum": 20,
          "minimum": 1,
          "title": "Max Injection Per Round",
          "type": "integer"
        }
      },
      "required": [],
      "additionalProperties": false
    },
    "buffer": {
      "type": "object",
      "properties": {
        "max_tokens": {
          "default": 3000,
          "title": "Max Tokens",
          "type": "integer"
        },
        "truncate_target": {
          "default": 2500,
          "title": "Truncate Target",
          "type": "integer"
        },
        "trigger_rounds": {
          "default": 5,
          "title": "Trigger Rounds",
          "type": "integer"
        },
        "rate_limit_seconds": {
          "default": 30,
          "title": "Rate Limit Seconds",
          "type": "integer"
        },
        "token_ratio": {
          "default": 0.75,
          "title": "Token Ratio",
          "type": "number"
        },
        "async_mode": {
          "default": true,
          "title": "Async Mode",
          "type": "boolean"
        },
        "subprocess_timeout": {
          "default": 300,
          "title": "Subprocess Timeout",
          "type": "integer"
        }
      },
      "required": [],
      "additionalProperties": false
    },
    "dashboard": {
      "type": "object",
      "properties": {
        "locale": {
          "default": "zh",
          "title": "Locale",
          "type": "string"
        },
        "status_cache_ttl": {
          "default": 15,
          "title": "Status Cache Ttl",
          "type": "integer"
        },
        "projects_cache_ttl": {
          "default": 30,
          "title": "Projects Cache Ttl",
          "type": "integer"
        },
        "health_check_timeout": {
          "default": 10,
          "title": "Health Check Timeout",
          "type": "integer"
        },
        "test_connection_timeout": {
          "default": 5,
          "title": "Test Connection Timeout",
          "type": "integer"
        },
        "search_default_top_k": {
          "default": 5,
          "title": "Search Default Top K",
          "type": "integer"
        },
        "search_top_k_max": {
          "default": 50,
          "title": "Search Top K Max",
          "type": "integer"
        },
        "search_default_decay": {
          "default": 0.02,
          "title": "Search Default Decay",
          "type": "number"
        },
        "search_default_bm25_weight": {
          "default": 0.7,
          "title": "Search Default Bm25 Weight",
          "type": "number"
        },
        "list_default_limit": {
          "default": 20,
          "title": "List Default Limit",
          "type": "integer"
        },
        "list_limit_max": {
          "default": 100,
          "title": "List Limit Max",
          "type": "integer"
        }
      },
      "required": [],
      "additionalProperties": false
    },
    "server": {
      "type": "object",
      "properties": {
        "id_length": {
          "default": 8,
          "title": "Id Length",
          "type": "integer"
        },
        "mcp_top_k_max": {
          "default": 20,
          "title": "Mcp Top K Max",
          "type": "integer"
        },
        "response_truncate_length": {
          "default": 100,
          "title": "Response Truncate Length",
          "type": "integer"
        },
        "mode": {
          "const": "unified",
          "default": "unified",
          "title": "Mode",
          "type": "string"
        },
        "host": {
          "default": "127.0.0.1",
          "title": "Host",
          "type": "string"
        },
        "port": {
          "default": 8000,
          "title": "Port",
          "type": "integer"
        }
      },
      "required": [],
      "additionalProperties": false
    },
    "auth": {
      "type": "object",
      "properties": {
        "disable": {
          "default": false,
          "title": "Disable",
          "type": "boolean"
        },
        "token_hash": {
          "default": "",
          "title": "Token Hash",
          "type": "string"
        },
        "secret_key": {
          "default": "",
          "title": "Secret Key",
          "type": "string"
        },
        "session_ttl": {
          "default": 86400,
          "title": "Session Ttl",
          "type": "integer"
        }
      },
      "required": [],
      "additionalProperties": false
    },
    "backup": {
      "type": "object",
      "properties": {
        "target_dir": {
          "default": "backups",
          "title": "Target Dir",
          "type": "string"
        },
        "max_backups": {
          "default": 10,
          "title": "Max Backups",
          "type": "integer"
        },
        "remind_after_days": {
          "default": 7,
          "title": "Remind After Days",
          "type": "integer"
        },
        "verify_after_backup": {
          "default": true,
          "title": "Verify After Backup",
          "type": "boolean"
        }
      },
      "required": [],
      "additionalProperties": false
    },
    "notification": {
      "type": "object",
      "properties": {
        "retention_days": {
          "default": 30,
          "title": "Retention Days",
          "type": "integer"
        },
        "rate_limit_minutes": {
          "default": 60,
          "title": "Rate Limit Minutes",
          "type": "integer"
        }
      },
      "required": [],
      "additionalProperties": false
    },
    "system_suggestion": {
      "type": "object",
      "properties": {
        "enabled": {
          "default": true,
          "description": "管道二全局开关",
          "title": "Enabled",
          "type": "boolean"
        },
        "daily_limit": {
          "default": 3,
          "description": "管道二每日推送上限",
          "maximum": 10,
          "minimum": 0,
          "title": "Daily Limit",
          "type": "integer"
        },
        "cooldown_hours": {
          "default": 24,
          "description": "同类事件冷却时间（小时）",
          "maximum": 168,
          "minimum": 1,
          "title": "Cooldown Hours",
          "type": "integer"
        },
        "triggers": {
          "description": "各事件独立开关",
          "properties": {
            "first_time_user": {
              "default": true,
              "description": "新用户首次对话（知识库为空）",
              "title": "First Time User",
              "type": "boolean"
            },
            "unrefined_rounds": {
              "default": true,
              "description": "大量对话未被提炼",
              "title": "Unrefined Rounds",
              "type": "boolean"
            },
            "low_quality_ratio": {
              "default": true,
              "description": "低质量记忆占比过高",
              "title": "Low Quality Ratio",
              "type": "boolean"
            },
            "no_daily_review": {
              "default": true,
              "description": "缺少日报/日报过期",
              "title": "No Daily Review",
              "type": "boolean"
            },
            "inactive_project": {
              "default": true,
              "description": "项目长时间无活动",
              "title": "Inactive Project",
              "type": "boolean"
            },
            "expired_memories": {
              "default": true,
              "description": "存在过期记忆未处理",
              "title": "Expired Memories",
              "type": "boolean"
            }
          },
          "title": "SystemSuggestionTriggers",
          "type": "object"
        }
      },
      "required": [],
      "additionalProperties": false
    },
    "agent": {
      "type": "object",
      "properties": {
        "enabled": {
          "default": true,
          "description": "Agent 决策引擎全局开关",
          "title": "Enabled",
          "type": "boolean"
        },
        "pattern_detection_enabled": {
          "default": true,
          "description": "模式检测开关（Phase 1）",
          "title": "Pattern Detection Enabled",
          "type": "boolean"
        },
        "daily_briefing_enabled": {
          "default": true,
          "description": "每日简报开关（Phase 2）",
          "title": "Daily Briefing Enabled",
          "type": "boolean"
        },
        "daily_briefing_time": {
          "default": "09:00",
          "description": "每日简报推送时间（HH:MM）",
          "title": "Daily Briefing Time",
          "type": "string"
        },
        "topic_cluster_window_days": {
          "default": 7,
          "description": "主题聚类窗口（天）",
          "maximum": 30,
          "minimum": 1,
          "title": "Topic Cluster Window Days",
          "type": "integer"
        },
        "recurrence_threshold": {
          "default": 3,
          "description": "重复问题触发阈值",
          "maximum": 10,
          "minimum": 2,
          "title": "Recurrence Threshold",
          "type": "integer"
        },
        "bug_match_similarity": {
          "default": 0.7,
          "description": "Bug 匹配相似度阈值",
          "maximum": 0.95,
          "minimum": 0.5,
          "title": "Bug Match Similarity",
          "type": "number"
        },
        "max_daily_briefing_items": {
          "default": 3,
          "description": "每日简报最大条目数",
          "maximum": 10,
          "minimum": 1,
          "title": "Max Daily Briefing Items",
          "type": "integer"
        },
        "briefing_cooldown_hours": {
          "default": 24,
          "description": "简报推送冷却（小时）",
          "maximum": 72,
          "minimum": 1,
          "title": "Briefing Cooldown Hours",
          "type": "integer"
        },
        "signal_cooldown_hours": {
          "default": 6,
          "description": "信号推送冷却（小时）",
          "maximum": 72,
          "minimum": 1,
          "title": "Signal Cooldown Hours",
          "type": "integer"
        },
        "max_active_signals": {
          "default": 5,
          "description": "最大活跃信号数",
          "maximum": 20,
          "minimum": 1,
          "title": "Max Active Signals",
          "type": "integer"
        }
      },
      "required": [],
      "additionalProperties": false
    },
    "hook_proxy": {
      "type": "object",
      "properties": {
        "timeout": {
          "default": 60,
          "minimum": 1,
          "title": "Timeout",
          "type": "integer"
        }
      },
      "required": [],
      "additionalProperties": false
    },
    "prompt": {
      "type": "object"
    }
  },
  "required": [
    "llm"
  ],
  "additionalProperties": false,
  "_schema_version": "0.5.1"
}