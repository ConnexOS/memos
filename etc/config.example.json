{
  "chroma": {
    "mode": "persistent",
    "path": "./memdb",
    "host": "localhost",
    "port": 8001,
    "collection_name": "project_memory",
    "timeout": 30
  },
  "model": {
    "name": "bge-large-zh-v1.5",
    "vector_dim": 1024,
    "download_retries": 3,
    "download_timeout": 600
  },
  "llm": {
    "endpoints": [
      {
        "name": "default",
        "api_base": "http://localhost:11434/v1",
        "api_key": "",
        "model": ""
      }
    ],
    "active": "default",
    "temperature": 0.1,
    "max_tokens": 2048,
    "request_timeout": 600
  },
  "memory": {
    "decay_lambda": 0.02,
    "similarity_threshold": 0.55,
    "default_top_k": 5
  },
  "buffer": {},
  "dashboard": {},
  "server": {},
  "auth": {
    "disable": false
  }
}
